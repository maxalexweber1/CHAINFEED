{
  "name": "chainfeed",
  "version": "0.0.1",
  "description": "Cardano-native oracle aggregator with x402 payment settlement, built on SAP CAP and ODATANO.",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@odatano/core": "^1.7.10",
    "@odatano/watch": "^0.1.8",
    "@odatano/x402": "^0.3.1",
    "@sap/cds": "^9",
    "express": "^4",
    "ink": "^5.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.16.0",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.29",
    "bip39": "^3.1.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "scripts": {
    "start": "cross-env CDS_TYPESCRIPT=1 NETWORK=mainnet NODE_OPTIONS=\"--import tsx\" cds-serve",
    "dev": "cross-env CDS_TYPESCRIPT=1 NETWORK=mainnet NODE_OPTIONS=\"--import tsx\" cds watch",
    "build": "cds build --production && tsc",
    "db:deploy": "cds deploy --to sqlite:db.sqlite",
    "db:reset": "node -e \"require('fs').rmSync('db.sqlite',{force:true})\" && npm run db:deploy",
    "typecheck": "tsc --noEmit",
    "check-no-js": "node -e \"const r=require('child_process').execSync('git ls-files srv scripts',{encoding:'utf8'}).split('\\n').filter(f=>/^(srv|scripts)\\/.+\\.js$/.test(f));if(r.length){console.error('TS-only policy: forbidden .js files:\\n'+r.join('\\n'));process.exit(1)}\"",
    "test": "npm run test:unit",
    "test:unit": "tsx scripts/test-all-unit.ts",
    "smoke": "tsx scripts/smoke-all.ts",
    "mcp": "tsx --env-file-if-exists=.env srv/mcp/server.ts",
    "mcp:http": "tsx --env-file-if-exists=.env srv/mcp/http.ts",
    "agent:dashboard": "tsx --env-file-if-exists=.env agents/dashboard/index.tsx",
    "agent:watcher": "tsx --env-file-if-exists=.env agents/watcher/index.ts",
    "agent:qa": "tsx --env-file-if-exists=.env agents/cli-qa/index.ts",
    "aiken:build": "cd contracts && aiken check && aiken build",
    "demo:aiken": "node --import tsx scripts/demo-aiken-flow.ts",
    "lint": "eslint .",
    "app:install": "npm --prefix app install",
    "app:dev": "npm --prefix app run dev",
    "app:build": "npm --prefix app run build",
    "app:typecheck": "npm --prefix app run typecheck"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      },
      "odatano-core": {
        "network": "mainnet",
        "backends": [
          "koios",
          "blockfrost"
        ],
        "blockfrostCustomBackend": "",
        "txBuilders": [
          "buildooor"
        ],
        "primaryTimeoutMs": 30000,
        "indexTtlMs": 3600000
      },
      "watch": {
        "network": "mainnet",
        "blockfrostCustomBackend": "",
        "koiosApiKey": "",
        "autoStart": false,
        "addressPolling": {
          "enabled": true,
          "interval": 300
        },
        "transactionPolling": {
          "enabled": false,
          "interval": 60
        },
        "credentialPolling": {
          "enabled": true,
          "interval": 300
        },
        "policyPolling": {
          "enabled": false,
          "interval": 60
        }
      }
    }
  }
}
