    "stop_loss/Datum": {
      "title": "Datum",
      "description": "Locked-in conditions, written by the owner at funding time.",
      "anyOf": [
        {
          "title": "Datum",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "owner_pkh",
              "description": "28-byte payment-key-hash that authorizes the `Withdraw` path.",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "liquidator_pkh",
              "description": "28-byte payment-key-hash that receives funds on `Liquidate`.",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "liquidation_price_milli_units",
              "description": "Floor price in milli-units (×1_000_000). Below this triggers liquidation.",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "chainfeed_pubkey",
              "description": "32-byte Ed25519 public key that CHAINFEED uses to sign quotes. Pin\n the pubkey itself (not just its hash) so verification is self-contained.",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "max_quote_age_ms",
              "description": "Maximum quote staleness accepted (in milliseconds). 5 min recommended.",
              "$ref": "#/definitions/Int"
            }
          ]
        }
      ]
    },
