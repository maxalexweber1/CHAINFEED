    "chainfeed/ChainfeedQuote": {
      "title": "ChainfeedQuote",
      "description": "A price quote as published by CHAINFEED. Field order is the canonical\n payload — DON'T reorder unless you also bump the off-chain encoder\n version. The price is fixed-point `value × 1_000_000` to avoid floats\n (Plutus has no floating-point support).",
      "anyOf": [
        {
          "title": "ChainfeedQuote",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "pair",
              "description": "Pair label as ASCII bytes — e.g. `#\"ADA-USD\"`. Pre-validate length\n off-chain; on-chain string-equality on ByteArray is cheap.",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "price_milli_units",
              "description": "Price multiplied by 1_000_000. ADA-USD at $0.6234 → 623_400.\n Range: ~9.2 × 10¹⁵ (Plutus Int is 64-bit-ish; safe for any peg).",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "valid_until_ms",
              "description": "POSIX milliseconds when the quote stops being valid (set by CHAINFEED\n based on TTL of the underlying source).",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "signed_at_ms",
              "description": "POSIX milliseconds when CHAINFEED produced the signature. Use with\n `is_fresh` to enforce a max-age window from the consumer's perspective.",
              "$ref": "#/definitions/Int"
            }
          ]
        }
      ]
    },
    "chainfeed/SignedQuote": {
      "title": "SignedQuote",
      "description": "A `ChainfeedQuote` plus its detached Ed25519 signature. This is the\n shape consumers should embed in their redeemer.",
      "anyOf": [
        {
          "title": "SignedQuote",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "quote",
              "$ref": "#/definitions/chainfeed~1ChainfeedQuote"
            },
            {
              "title": "signature",
              "description": "64-byte raw Ed25519 signature over `cbor.serialise(quote)`.",
              "$ref": "#/definitions/ByteArray"
            }
          ]
        }
      ]
    },
