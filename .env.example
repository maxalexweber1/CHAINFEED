# CHAINFEED - environment variable template
# Copy to `.env.local` (gitignored) and fill in. CAP picks env vars up via
# its `default-env.json` mechanism, OR you can `set -a; source .env.local`
# before `npm run dev`. We use direct shell sourcing.
# DO NOT COMMIT. Faucet preprod tADA to X402_PAY_TO_PREPROD before minting mock-USDM.
CHAINFEED_WALLET_MNEMONIC="test agent wallet mnemonic goes here"

# Active receiver address (default to preprod for dev)
X402_PAY_TO=addr_test1qpw6y2yq73qhxycl73snjgf9anc879tqvqg4rvssjms3y6kwnd9ygjx5ds9sc69u2sk7z6g72fupwvtnxx4j5vwr0t7skzugf0

# ODATANO — preprod
NETWORK=preprod
BACKENDS=blockfrost
TX_BUILDERS=buildooor
BLOCKFROST_API_KEY=your_blockfrost_api_key_here
# Cardano-x402-v2 network identifier — colon-form ('cardano:<net>').
X402_NETWORK=cardano:preprod
X402_USDM_NAME_HEX=0014df105553444d
# X402_USDM_POLICY filled in after the mock-USDM mint runs
X402_USDM_POLICY=a62434701e2b8904096511fe2879efc920d18559ea1ae7a9dd52bd72

# Webhook-secret encryption key (AES-256-GCM, 32 bytes / 64 hex chars).
# Used to encrypt `AlertSubscriptions.hmacSecretHex` at rest. Without this,
# the server warns + stores secrets in cleartext (dev only). In production
# (NODE_ENV=production), boot aborts if unset.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CHAINFEED_SUBSCRIPTION_KEK_HEX=

# ── Demo agents (agents/watcher, agents/dashboard) ─────────────────────
# Where the dashboard + watcher reach the local MCP HTTP server. Use
# 127.0.0.1 not localhost — Node 18+ resolves localhost to ::1 first and
# CAP binds only IPv4 (would yield "fetch failed").
MCP_URL=http://127.0.0.1:4005/mcp

# Same reason as above — set this when running `npm run mcp:http` so the
# MCP server reaches CHAINFEED OData via IPv4, not IPv6 localhost.
CHAINFEED_BASE_URL=http://127.0.0.1:4004

# Watcher output sinks. Each is opt-in: leave the var unset to disable
# that sink. stdout is always on (deploy-log trail). To rotate either,
# regenerate the secret on the upstream service then update here.
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Watcher cadence (ms) — default 60_000. Lower in dev if you want
# alerts to fire faster while triggering test changes.
WATCHER_INTERVAL_MS=60000

# ── CLI Q&A agent (agents/cli-qa) ────────────────────────────────────────
# `npm run agent:qa` is a natural-language Claude-driven REPL that talks
# to the local MCP server. Get a key at https://console.anthropic.com.
# Default model is Haiku 4.5 (fast + cheap); override via ANTHROPIC_MODEL
# if you want Sonnet 4.6 or Opus 4.7.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
